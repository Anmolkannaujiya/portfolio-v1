# Portfolio Contact Form Configuration
# Copy this file to .env.local and fill in your values

# Email configuration for contact form
# Option 1: Use a service like EmailJS, Resend, or Nodemailer
CONTACT_EMAIL_TO=anmolkannaujiya@outlook.com
CONTACT_EMAIL_FROM=noreply@yourportfolio.com

# If using Resend (recommended)
RESEND_API_KEY=your_resend_api_key_here

# If using EmailJS
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
